# CampusFlow Frontend Environment Configuration

# ── Stellar Network & Contract ───────────────────────────────────────
# Testnet - Used for development and testing
VITE_CONTRACT_ID=CA4KZTR6TY56RNE47HT6GFPYE32MFGLVGTGT2FPNNBD74MHZ2TJGICNG

# Mainnet - Deploy your contract here for production
# VITE_MAINNET_CONTRACT_ID=<deploy-your-contract-to-mainnet-and-add-id>

# Default network on startup
VITE_DEFAULT_NETWORK=TESTNET

# ── Development ──────────────────────────────────────────────────────
# Set to true to see verbose contract call logs
VITE_DEBUG=false

# ── Build ────────────────────────────────────────────────────────────
# Source maps for development (disable in production)
VITE_SOURCEMAP=true
